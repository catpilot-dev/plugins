{
  "id": "phone_display",
  "name": "Phone Display",
  "version": "1.0.0",
  "type": "hybrid",
  "author": "catpilot",
  "description": "Monitors WebRTC phone display session. On RK3588 (headless), phone display is mandatory and blocks engagement when disconnected. On Comma devices, opt-in via CatEyePhoneRequired toggle.",
  "min_openpilot": "0.10.0",
  "max_openpilot": "0.11.99",
  "cereal": {
    "event_names": {
      "phoneDisplayUnavailable": 99
    }
  },
  "hooks": {
    "webrtc.app_routes": {
      "module": "hook",
      "function": "on_webrtc_app_routes",
      "priority": 50
    },
    "webrtc.session_started": {
      "module": "hook",
      "function": "on_webrtc_session_started",
      "priority": 50
    },
    "webrtc.session_ended": {
      "module": "hook",
      "function": "on_webrtc_session_ended",
      "priority": 50
    },
    "selfdrived.alert_registry": {
      "module": "hook",
      "function": "on_alert_registry",
      "priority": 50
    },
    "selfdrived.events": {
      "module": "hook",
      "function": "on_selfdrived_events",
      "priority": 50
    },
    "device.health_check": {
      "module": "hook",
      "function": "on_health_check",
      "priority": 50
    }
  },
  "processes": [
    {
      "name": "phone_watchdog",
      "module": "watchdog",
      "condition": "only_onroad"
    }
  ],
  "params": {
    "CatEyePhoneRequired": {
      "type": "bool",
      "default": false,
      "label": "Phone Display Required",
      "desc": "Block engagement when no phone is connected via WebRTC. Always active on headless (RK3588) devices.",
      "deviceParam": true
    }
  }
}
