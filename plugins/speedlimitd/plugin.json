{
  "id": "speedlimitd",
  "name": "Speed Limit Daemon",
  "version": "1.0.0",
  "type": "hybrid",
  "author": "c3pilot",
  "description": "Speed limit middleware: fuses OSM maxspeed, YOLO detection, and road-type inference into speedLimitState. Enforces confirmed speed limits via cruise speed reduction.",
  "min_openpilot": "0.10.0",
  "max_openpilot": "0.10.99",
  "dependencies": ["mapd"],
  "cereal": {
    "slots": {
      "0": {
        "struct_name": "SpeedLimitState",
        "event_field": "speedLimitState",
        "schema_file": "cereal/slot0.capnp"
      }
    }
  },
  "services": {
    "speedLimitState": [true, 1.0, 1]
  },
  "hooks": {
    "planner.subscriptions": {
      "module": "planner_hook",
      "function": "on_planner_subscriptions",
      "priority": 50
    },
    "planner.v_cruise": {
      "module": "planner_hook",
      "function": "on_v_cruise",
      "priority": 50
    },
    "ui.render_overlay": {
      "module": "ui_overlay",
      "function": "on_render_overlay",
      "priority": 50
    },
    "ui.state_subscriptions": {
      "module": "ui_overlay",
      "function": "on_state_subscriptions",
      "priority": 50
    }
  },
  "processes": [
    {
      "name": "speedlimitd",
      "module": "speedlimitd",
      "condition": "only_onroad",
      "requires": {"services": ["mapdOut"], "timeout": 1000}
    }
  ],
  "params": {
    "ShowSpeedLimitSign": {
      "type": "bool",
      "default": true,
      "label": "Show Speed Limit Sign",
      "desc": "Display speed limit sign on HUD"
    },
    "ShowCurvatureSpeed": {
      "type": "bool",
      "default": true,
      "label": "Show Curvature Speed",
      "desc": "Display recommended curve speed on HUD"
    },
    "MapdSpeedLimitControlEnabled": {
      "type": "bool",
      "default": false,
      "label": "Map Speed Control",
      "desc": "Automatically limit speed based on OSM map data",
      "requiresPlugin": "mapd"
    },
    "MapdSpeedLimitOffsetPercent": {
      "type": "pills",
      "default": 10,
      "label": "Speed Offset",
      "desc": "Percentage above the posted speed limit",
      "options": [0, 5, 10, 15],
      "suffix": "%",
      "dependsOn": "MapdSpeedLimitControlEnabled"
    },
    "MapdCurveTargetLatAccel": {
      "type": "pills",
      "default": 1,
      "label": "Curve Comfort",
      "desc": "Target lateral acceleration in curves (m/s\u00b2)",
      "options": ["1.5", "2.0", "2.5", "3.0"],
      "dependsOn": "MapdSpeedLimitControlEnabled"
    },
    "SpeedLimitConfirmed": {
      "type": "string",
      "default": "0"
    },
    "SpeedLimitValue": {
      "type": "string",
      "default": ""
    }
  }
}
