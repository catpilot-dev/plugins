{
  "id": "speedlimitd",
  "name": "Speed Limit Daemon",
  "version": "1.1.0",
  "type": "hybrid",
  "author": "catpilot",
  "description": "Speed limit middleware: fuses OSM maxspeed, YOLO detection, and road-type inference into speedLimitState via plugin_bus. Enforces confirmed speed limits via cruise speed reduction.",
  "min_openpilot": "0.10.0",
  "max_openpilot": "0.11.99",
  "dependencies": [],
  "hooks": {
    "planner.v_cruise": {
      "module": "planner_hook",
      "function": "on_v_cruise",
      "priority": 50
    },
    "ui.hud_set_speed_override": {
      "module": "ui_overlay",
      "function": "on_hud_set_speed_override",
      "priority": 50
    },
    "ui.render_overlay": {
      "module": "ui_overlay",
      "function": "on_render_overlay",
      "priority": 50
    },
    "device.health_check": {
      "module": "planner_hook",
      "function": "on_health_check",
      "priority": 50
    }
  },
  "processes": [
    {
      "name": "speedlimitd",
      "module": "speedlimitd",
      "condition": "only_onroad",
      "requires": {}
    }
  ],
  "params": {
    "ShowSpeedLimitSign": {
      "type": "bool",
      "default": true,
      "label": "Show Speed Limit Sign",
      "desc": "Display speed limit sign on HUD"
    }
  }
}
