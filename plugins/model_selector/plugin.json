{
  "id": "model_selector",
  "name": "Model Selector",
  "version": "1.0.0",
  "type": "hook",
  "description": "Download and swap driving and DM models from openpilot GitHub commits",
  "hooks": {
    "ui.software_settings_extend": {
      "module": "ui",
      "function": "on_software_settings_extend",
      "priority": 50
    },
    "device.health_check": {
      "module": "ui",
      "function": "on_health_check",
      "priority": 50
    }
  }
}
